# qr-catalog-backend/Dockerfile
FROM python:3.11-slim

WORKDIR /app

# Instalar dependencias del sistema necesarias
RUN apt-get update && apt-get install -y \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Copiar requirements primero (para cachear capas)
COPY requirements.txt .

# Instalar dependencias Python - INCLUYENDO FPDF2
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir fpdf2  # 👈 INSTALACIÓN EXPLÍCITA

# Verificar instalación (opcional, para depurar)
RUN python -c "import fpdf; print('✅ FPDF instalado correctamente')"

# Copiar el resto del código
COPY . .

# Crear directorio para uploads
RUN mkdir -p /app/uploads

# Exponer puerto
EXPOSE 8000

# Comando para ejecutar la aplicación
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]